<mujoco model="panda pick and place">
  <include file="scene.xml"/>

  <worldbody>
    <!-- Object to pick up: small green box with freejoint (Tuned for easier grasping) -->
    <body name="object" pos="0.5 0 0.02">
      <freejoint name="object_joint"/>
      <geom type="box" name="object" size="0.02 0.02 0.02" rgba="0 1 0 1"
        mass="0.05" condim="4" friction="3 0.05 0.0001"
        contype="1" conaffinity="1" solref="0.02 1" solimp="0.9 0.95 0.001"/>
    </body>

    <!-- Target placement location (mocap body, visual only) -->
    <body name="target" pos="0.5 0.2 0.02" mocap="true">
      <site name="target_site" type="sphere" size="0.02" rgba="1 0 0 0.5"/>
    </body>
  </worldbody>

  <!-- Override panda.xml keyframe to include object freejoint DOFs -->
  <!-- qpos: 7 arm joints + 2 finger joints + 3 object pos + 4 object quat = 16 -->
  <!-- ctrl: 7 arm actuators + 1 gripper actuator = 8 -->
  <keyframe>
    <key name="pick_and_place_home"
      qpos="0 0 0 -1.57079 0 1.57079 -0.7853 0.04 0.04 0.5 0 0.02 1 0 0 0"
      ctrl="0 0 0 -1.57079 0 1.57079 -0.7853 255"/>
  </keyframe>
</mujoco>
